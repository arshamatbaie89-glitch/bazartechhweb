# SECURITY: Generate a strong random secret (min 32 chars)
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_32_CHAR_STRING

DATABASE_URL="file:./dev.db"

# Set to "true" in production behind HTTPS
COOKIE_SECURE=true

# Your production domain
NEXT_PUBLIC_SITE_URL="https://yourdomain.com"

# SMTP Email (for OTP delivery in production)
# Gmail: use an App Password (requires 2FA on your account)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Mallmart <your-email@gmail.com>"

# Social links
NEXT_PUBLIC_INSTAGRAM_URL="https://www.instagram.com/your-store"
NEXT_PUBLIC_WHATSAPP_NUMBER="96897484837"
