# ─── Database ───────────────────────────────────────────
# SQLite file path (relative to project root)
DATABASE_URL="file:./dev.db"

# ─── Authentication ─────────────────────────────────────
# Generate a strong random secret (min 32 hex chars):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING

# Set to "true" when serving over HTTPS (production)
COOKIE_SECURE=false

# ─── Site Configuration ─────────────────────────────────
# Your public site URL (used for OG tags, social links)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_INSTAGRAM_URL="https://www.instagram.com/your-store"
NEXT_PUBLIC_WHATSAPP_NUMBER="96897484837"

# ─── Email (SMTP) — optional, for OTP delivery ─────────
# Leave commented out to use console-based OTP (dev only)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="Bazartech <your-email@gmail.com>"
